# Required - config.Load() returns an error if this is unset.
DATABASE_URL=postgres://postgres:supersecret@localhost:5432/blueprint

# Optional - defaults shown are what config.Load() falls back to if unset.
PORT=8080
APP_ENV=development
FRONTEND_URL=http://localhost:3000
TRUST_PROXY_HEADERS=false
DB_MAX_CONNS=25
DB_MIN_CONNS=5